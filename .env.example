# Firebase Configuration (Development)
# JANGAN COMMIT FILE INI KE GIT - Untuk development lokal saja
#
# Isi dengan credentials dari Firebase Console, kemudian ubah nama file menjadi .env
# Baca FIREBASE_SETUP.md untuk langkah-langkah detail

FIREBASE_WEB_API_KEY=YOUR_WEB_API_KEY_HERE
FIREBASE_WEB_APP_ID=YOUR_WEB_APP_ID_HERE
FIREBASE_WEB_MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID_HERE
FIREBASE_WEB_PROJECT_ID=YOUR_PROJECT_ID_HERE
FIREBASE_WEB_AUTH_DOMAIN=YOUR_PROJECT_ID_HERE.firebaseapp.com
FIREBASE_WEB_DATABASE_URL=https://YOUR_PROJECT_ID_HERE-default-rtdb.REGION.firebasedatabase.app
FIREBASE_WEB_STORAGE_BUCKET=YOUR_PROJECT_ID_HERE.appspot.com
FIREBASE_WEB_MEASUREMENT_ID=YOUR_WEB_MEASUREMENT_ID_HERE

FIREBASE_ANDROID_API_KEY=YOUR_ANDROID_API_KEY_HERE
FIREBASE_ANDROID_APP_ID=YOUR_ANDROID_APP_ID_HERE
FIREBASE_ANDROID_MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID_HERE
FIREBASE_ANDROID_PROJECT_ID=YOUR_PROJECT_ID_HERE
FIREBASE_ANDROID_DATABASE_URL=https://YOUR_PROJECT_ID_HERE-default-rtdb.REGION.firebasedatabase.app
FIREBASE_ANDROID_STORAGE_BUCKET=YOUR_PROJECT_ID_HERE.appspot.com

