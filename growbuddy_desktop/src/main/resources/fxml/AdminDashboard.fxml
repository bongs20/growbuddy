<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="800.0" prefWidth="1200.0" style="-fx-background-color: #F8FAFC;" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bongs20.growbuddy.controllers.AdminDashboardController">
   <children>
      <VBox spacing="24.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            
            <!-- Sleek Modern Header -->
            <HBox alignment="CENTER_LEFT" prefHeight="70.0" style="-fx-background-color: white; -fx-padding: 0 32; -fx-effect: dropshadow(three-pass-box, rgba(0, 0, 0, 0.04), 16, 0, 0, 4);">
               <children>
                  <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #376A25;" text="Admin Dashboard" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Button mnemonicParsing="false" onAction="#handleLogout" style="-fx-background-color: #FEE2E2; -fx-text-fill: #991B1B; -fx-background-radius: 12; -fx-font-weight: bold; -fx-padding: 10 20; -fx-cursor: hand;" text="Keluar" />
               </children>
            </HBox>

            <VBox spacing="24.0" VBox.vgrow="ALWAYS">
               <padding>
                  <Insets bottom="32.0" left="32.0" right="32.0" top="8.0" />
               </padding>
               <children>
                  <!-- Inner Dashboard Card -->
                  <VBox spacing="24.0" styleClass="card" VBox.vgrow="ALWAYS">
                     <children>
                        <HBox alignment="CENTER_LEFT">
                           <children>
                              <VBox spacing="4.0">
                                 <children>
                                    <Label style="-fx-font-size: 20px; -fx-font-weight: 800; -fx-text-fill: #0F172A;" text="Daftar Perangkat Aktif" />
                                    <Label styleClass="text-gray" style="-fx-font-size: 14px;" text="Kelola, pantau, dan tambahkan node perangkat IoT GrowBuddy Anda." />
                                 </children>
                              </VBox>
                              <Region HBox.hgrow="ALWAYS" />
                              <Button mnemonicParsing="false" onAction="#handleAddDevice" styleClass="btn-primary" style="-fx-padding: 10 20; -fx-font-size: 14px;" text="+ Daftarkan Perangkat" />
                           </children>
                        </HBox>
                        
                        <TableView fx:id="deviceTable" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #E2E8F0; -fx-border-radius: 16; -fx-padding: 8;">
                          <columns>
                            <TableColumn fx:id="colDeviceId" prefWidth="200.0" text="Device ID" />
                            <TableColumn fx:id="colStatus" prefWidth="180.0" text="Status" />
                            <TableColumn fx:id="colConnection" prefWidth="180.0" text="Koneksi" />
                            <TableColumn fx:id="colMoisture" prefWidth="160.0" text="Moisture" />
                            <TableColumn fx:id="colLastUpdate" prefWidth="250.0" text="Update Terakhir" />
                          </columns>
                        </TableView>
                     </children>
                  </VBox>
               </children>
            </VBox>
            
         </children>
      </VBox>
   </children>
</AnchorPane>
