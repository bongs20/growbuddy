<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<ScrollPane fitToWidth="true" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bongs20.growbuddy.controllers.HomeDashboardController">
    <content>
        <VBox spacing="32.0" maxWidth="1100">
            <padding>
                <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
            </padding>

            <Label styleClass="heading" text="GrowBuddy Dashboard" />

            <HBox spacing="32.0">
                <!-- Left Column (Main Info) -->
                <VBox spacing="32.0" HBox.hgrow="ALWAYS" prefWidth="600">
                    <!-- Device Summary Card -->
                    <VBox styleClass="card, card-device" spacing="32.0">
                        <HBox alignment="CENTER_LEFT" spacing="16.0">
                            <VBox HBox.hgrow="ALWAYS">
                                <Label fx:id="deviceIdLabel" style="-fx-font-size: 24px; -fx-font-weight: 900; -fx-text-fill: #0F172A;" text="Device ID" />
                                <Label fx:id="statusLabel" styleClass="text-gray" text="Status" />
                            </VBox>
                            <Region HBox.hgrow="ALWAYS" />
                            <Label fx:id="onlineBadge" styleClass="badge-offline" text="Offline" />
                        </HBox>

                        <VBox spacing="16.0">
                            <Label styleClass="text-bold" text="Kelembapan Tanah" />
                            <ProgressBar fx:id="moistureProgress" maxWidth="Infinity" progress="0.0" styleClass="progress-bar-green" />
                            <Label fx:id="moistureLabel" styleClass="text-green" style="-fx-font-size: 48px; -fx-font-weight: 900;" text="0%" />
                        </VBox>
                    </VBox>
                </VBox>
                
                <!-- Right Column (Metrics & Controls) -->
                <VBox spacing="32.0" HBox.hgrow="ALWAYS" prefWidth="400">
                    <!-- Metrics Row -->
                    <HBox spacing="16.0">
                        <VBox HBox.hgrow="ALWAYS" styleClass="card" spacing="8.0" alignment="CENTER">
                            <Label fx:id="scoreLabel" style="-fx-font-size: 32px; -fx-font-weight: 900; -fx-text-fill: #059669;" text="0" />
                            <Label styleClass="text-gray" text="Score" />
                        </VBox>
                        <VBox HBox.hgrow="ALWAYS" styleClass="card" spacing="8.0" alignment="CENTER">
                            <Label fx:id="levelLabel" style="-fx-font-size: 32px; -fx-font-weight: 900; -fx-text-fill: #2563EB;" text="0" />
                            <Label styleClass="text-gray" text="Level" />
                        </VBox>
                    </HBox>

                    <!-- Control Card -->
                    <VBox styleClass="card" spacing="20.0" VBox.vgrow="ALWAYS">
                        <Label styleClass="text-bold" style="-fx-font-size: 20px; -fx-text-fill: #0F172A;" text="Kontrol Penyiraman" />
                        <Label styleClass="text-gray" text="Tekan tombol untuk meminta perangkat menyiram tanaman." wrapText="true" />
                        <Region VBox.vgrow="ALWAYS" />
                        <Button fx:id="btnSiram" maxWidth="Infinity" mnemonicParsing="false" styleClass="btn-primary" text="Siram Sekarang" />
                    </VBox>
                </VBox>
            </HBox>
        </VBox>
    </content>
</ScrollPane>
