<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.shape.SVGPath?>

<BorderPane prefHeight="800.0" prefWidth="1200.0" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bongs20.growbuddy.controllers.MainLayoutController">
    <!-- Left Navigation Sidebar -->
    <left>
        <VBox prefWidth="260.0" styleClass="sidebar" spacing="8.0">
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="32.0" />
            </padding>
            <children>
                <Label text="GrowBuddy" styleClass="sidebar-title" />
                <Label text="Admin Dashboard" style="-fx-text-fill: #94A3B8; -fx-font-size: 14px; -fx-padding: 0 0 32 0;" />
                
                <Button fx:id="btnHome" maxWidth="Infinity" mnemonicParsing="false" onAction="#showHome" styleClass="nav-button, nav-active" text="Beranda" graphicTextGap="12">
                    <graphic>
                        <SVGPath content="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z" styleClass="svg-icon" />
                    </graphic>
                </Button>
                <Button fx:id="btnHistory" maxWidth="Infinity" mnemonicParsing="false" onAction="#showHistory" styleClass="nav-button" text="Riwayat" graphicTextGap="12">
                    <graphic>
                        <SVGPath content="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z" styleClass="svg-icon" />
                    </graphic>
                </Button>
                <Button fx:id="btnMissions" maxWidth="Infinity" mnemonicParsing="false" onAction="#showMissions" styleClass="nav-button" text="Misi" graphicTextGap="12">
                    <graphic>
                        <SVGPath content="M19 5h-2V3H7v2H5c-1.1 0-2 .9-2 2v3c0 2.24 1.5 4.13 3.6 4.78C7.12 13.3 8.4 14 10 14v4H7v2h10v-2h-3v-4c1.6 0 2.88-.7 3.4-1.22 2.1-1.05 3.6-2.94 3.6-5.18V7c0-1.1-.9-2-2-2zm-12 5V7h2v3c0 .55-.45 1-1 1s-1-.45-1-1zm10 0c0 .55-.45 1-1 1s-1-.45-1-1V7h2v3z" styleClass="svg-icon" />
                    </graphic>
                </Button>
                <Button fx:id="btnSettings" maxWidth="Infinity" mnemonicParsing="false" onAction="#showSettings" styleClass="nav-button" text="Pengaturan" graphicTextGap="12">
                    <graphic>
                        <SVGPath content="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z" styleClass="svg-icon" />
                    </graphic>
                </Button>
                
                <Region VBox.vgrow="ALWAYS" />
                <Label text="GrowBuddy Desktop v1.0" style="-fx-text-fill: #94A3B8; -fx-font-size: 12px; -fx-alignment: center;" maxWidth="Infinity" />
            </children>
        </VBox>
    </left>

    <!-- Center Content Area -->
    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #F8FAFC;" />
    </center>
</BorderPane>
