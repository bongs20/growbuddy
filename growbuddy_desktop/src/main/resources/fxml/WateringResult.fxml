<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="800.0" prefWidth="480.0" style="-fx-background-color: #FFF9E7;" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bongs20.growbuddy.controllers.WateringResultController">
   <children>
      <VBox alignment="CENTER" spacing="24.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="24.0" AnchorPane.rightAnchor="24.0" AnchorPane.topAnchor="0.0">
         <children>
            
            <Label alignment="CENTER" prefHeight="100.0" prefWidth="100.0" style="-fx-background-color: #EAF7EC; -fx-background-radius: 999; -fx-text-fill: #376A25; -fx-font-size: 50px;" text="✅" />
            
            <Label style="-fx-font-size: 24px; -fx-font-weight: 800; -fx-text-fill: #1E1C0F;" text="Penyiraman Selesai" />
            
            <Label style="-fx-font-size: 16px; -fx-text-fill: #5E6653;" text="Sistem berhasil menyiram tanamanmu. Berikut adalah detail evaluasi dari sistem kami." textAlignment="CENTER" wrapText="true" />
            
            <HBox spacing="16.0" style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 16;">
               <children>
                  <VBox HBox.hgrow="ALWAYS">
                     <children>
                        <Label style="-fx-font-size: 14px; -fx-font-weight: 700; -fx-text-fill: #42493D;" text="Skor Diperoleh" />
                        <Label fx:id="scoreLabel" style="-fx-font-size: 24px; -fx-font-weight: 800; -fx-text-fill: #376A25;" text="-" />
                     </children>
                  </VBox>
                  <VBox HBox.hgrow="ALWAYS">
                     <children>
                        <Label style="-fx-font-size: 14px; -fx-font-weight: 700; -fx-text-fill: #42493D;" text="Kelembapan Akhir" />
                        <Label fx:id="moistureLabel" style="-fx-font-size: 24px; -fx-font-weight: 800; -fx-text-fill: #376A25;" text="-%" />
                     </children>
                  </VBox>
               </children>
            </HBox>
            
            <Region VBox.vgrow="ALWAYS" />
            
            <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleBack" prefHeight="54.0" style="-fx-background-color: #376A25; -fx-text-fill: white; -fx-background-radius: 18; -fx-font-weight: 700; -fx-font-size: 16px;" text="Kembali ke Dasbor" />

         </children>
      </VBox>
   </children>
</AnchorPane>
