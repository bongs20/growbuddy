<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bongs20.growbuddy.controllers.AutoLoginController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <Label styleClass="heading" text="Halo, Plant Hero!" />
    
    <Label styleClass="subheading" text="Menghubungkan aplikasi..." />
    
    <ProgressIndicator />

    <Label fx:id="statusLabel" styleClass="text-gray" text="Menyiapkan koneksi Firebase..." />

</VBox>
